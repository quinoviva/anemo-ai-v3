    "\n",
    "# ── 3. Synthetic (700/class x 4 classes x 3 body parts = 8 400 images) ────\n",
    "# No public nailbed or palm datasets exist on any platform.\n",
    "# Synthetic uses clinical HSV pallor ranges (Fitzpatrick skin-tone variants).\n",
    "# References: Sheth TN et al. 1997 NEJM, Nevo S et al. 1998, Kalantri A et al. 2010 BMC\n",
    "print()\n",
    "print(\"=\"*60)\n",
    "print(\"SOURCE 3: Synthetic images - 700/class x 4 classes x 3 body parts\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "def generate_synthetic_images(dest_dir, body_part, n_per_class=1000):\n",
    "    RANGES = {\n",
    "        \"conjunctiva\": {\n",
    "            \"0_Normal\":   {\"h\":(0,15),  \"s\":(90,170),\"v\":(180,240)},\n",
    "            \"1_Mild\":     {\"h\":(0,12),  \"s\":(65,130),\"v\":(160,220)},\n",
    "            \"2_Moderate\": {\"h\":(0,10),  \"s\":(30,90), \"v\":(140,200)},\n",
    "            \"3_Severe\":   {\"h\":(0, 8),  \"s\":(10,50), \"v\":(110,170)},\n",
    "        },\n",
    "        \"nailbed\": {\n",
    "            \"0_Normal\":   {\"h\":(0,15),  \"s\":(50,110),\"v\":(190,245)},\n",
    "            \"1_Mild\":     {\"h\":(0,12),  \"s\":(35,85), \"v\":(170,225)},\n",
    "            \"2_Moderate\": {\"h\":(0,10),  \"s\":(18,55), \"v\":(145,205)},\n",
    "            \"3_Severe\":   {\"h\":(0, 8),  \"s\":(5, 30), \"v\":(115,175)},\n",
    "        },\n",
    "        \"palm\": {\n",
    "            \"0_Normal\":   {\"h\":(5,20),  \"s\":(70,150),\"v\":(170,235)},\n",
    "            \"1_Mild\":     {\"h\":(5,18),  \"s\":(50,115),\"v\":(155,215)},\n",
    "            \"2_Moderate\": {\"h\":(3,15),  \"s\":(25,80), \"v\":(135,195)},\n",
    "            \"3_Severe\":   {\"h\":(2,12),  \"s\":(8, 40), \"v\":(105,165)},\n",
    "        },\n",
    "    }\n",
    "    SKIN_TONE_V = [0, -15, -30, -50]\n",
    "    ranges = RANGES.get(body_part, RANGES[\"conjunctiva\"])\n",
    "    rng = np.random.default_rng(42)\n",
    "    Path(dest_dir).mkdir(parents=True, exist_ok=True)\n",
    "    IH, IW = 224, 224\n",
    "    total = 0\n",
    "\n",
    "    def _add_conjunctiva_features(rgb, rng, pallor):\n",
    "        \"\"\"Horizontal blood vessels + mucosal fold — looks like inner eyelid.\"\"\"\n",
    "        out = rgb.astype(np.float32)\n",
    "        # Add horizontal lower-lid fold line\n",
    "        out = np.clip(out, 0, 255).astype(np.uint8)  # convert once; cv2 draws in-place on this array
        fold_y = int(rng.uniform(IH * 0.60, IH * 0.78))\n",
    "        fold_col = [max(0, int(rgb[fold_y, IW//2, c]) - 30) for c in range(3)]\n",
    "        cv2.line(out, (0, fold_y), (IW, fold_y + int(rng.uniform(-8, 8))), fold_col, int(rng.integers(2, 4)))\n",
    "        # Draw horizontal blood vessels (conjunctival vessels are horizontal)\n",
    "        n_vessels = int(rng.integers(4, 10))\n",
    "        for _ in range(n_vessels):\n",
    "            y_start = int(rng.uniform(20, IH - 40))\n",
    "            x_start = int(rng.uniform(0, 30))\n",
    "            # Vessels curve slightly and branch\n",
    "            pts = [(x_start, y_start)]\n",
    "            xc = x_start\n",
    "            for step in range(int(rng.integers(8, 18))):\n",
    "                xc += int(rng.uniform(8, 18))\n",
    "                yc = int(np.clip(pts[-1][1] + rng.uniform(-6, 6), 5, IH - 5))\n",
    "                pts.append((xc, yc))\n",
    "                if xc >= IW - 5:\n",
    "                    break\n",
    "            arr = np.array(pts, dtype=np.int32)\n",
    "            # Vessel colour: darker red channel, close to base colour\n",
    "            vc = [max(0, int(rgb[y_start, min(x_start, IW-1), c]) - int(rng.uniform(35, 70))) for c in range(3)]\n",
    "            w = int(rng.integers(1, 3))\n",
    "            cv2.polylines(out, [arr], False, vc, w)\n",
    "            # Short branches off main vessel\n",
    "            if len(pts) > 3 and rng.random() > 0.4:\n",
    "                bp_idx = int(rng.integers(1, len(pts) - 1))\n",
    "                bx, by = pts[bp_idx]\n",
    "                ex = int(np.clip(bx + rng.uniform(-20, 20), 0, IW - 1))\n",
    "                ey = int(np.clip(by + rng.uniform(-25, -5), 0, IH - 1))\n",
    "                cv2.line(out, (bx, by), (ex, ey), vc, 1)\n",
    "        return np.clip(out, 0, 255).astype(np.uint8)\n",
    "\n",
    "    def _add_nailbed_features(rgb, rng, pallor):\n",
    "        \"\"\"Oval nail plate shape + lunula + horizontal striations.\"\"\"\n",
    "        out = rgb.astype(np.float32)\n",
    "        cx, cy = IW // 2, IH // 2\n",
    "        ax = int(rng.uniform(78, 100))\n",
    "        ay = int(rng.uniform(60, 88))\n",
    "        Y, X = np.ogrid[:IH, :IW]\n",
    "        nail_mask = ((X - cx)**2 / ax**2 + (Y - cy)**2 / ay**2) <= 1.0\n",
    "        # Darken outside nail plate to simulate finger skin border\n",
    "        out[~nail_mask] = np.clip(out[~nail_mask] * 0.75, 0, 255)\n",
    "        # Lunula: lighter crescent at bottom of nail plate\n",
    "        lun_cy = cy + int(rng.uniform(ay * 0.5, ay * 0.75))\n",
    "        lun_ax = int(rng.uniform(28, 45))\n",
    "        lun_ay = int(rng.uniform(16, 26))\n",
    "        lun_mask = (nail_mask &\n",
    "                    (((X - cx)**2 / lun_ax**2 + (Y - lun_cy)**2 / lun_ay**2) <= 1.0))\n",
    "        out[lun_mask] = np.clip(out[lun_mask] + rng.uniform(18, 35), 0, 255)\n",
    "        # Nail border highlight\n",
    "        border_mask = (((X - cx)**2 / ax**2 + (Y - cy)**2 / ay**2) > 0.85) & nail_mask\n",
    "        out[border_mask] = np.clip(out[border_mask] * 0.88, 0, 255)\n",
    "        # Horizontal striations across nail plate\n",
    "        out = np.clip(out, 0, 255).astype(np.uint8)  # convert once before cv2 striation drawing\n",
    "        step = int(rng.integers(12, 22))\n",
    "        for yi in range(cy - ay, cy + ay, step):\n",
    "            if 0 <= yi < IH:\n",
    "                row_pts = [(xi, yi) for xi in range(IW) if nail_mask[yi, xi]]\n",
    "                if len(row_pts) >= 2:\n",
    "                    x0, x1_ = row_pts[0][0], row_pts[-1][0]\n",
    "                    sc = [max(0, int(out[yi, (x0+x1_)//2, c]) - int(rng.uniform(6, 16))) for c in range(3)]\n",
    "                    cv2.line(out, (x0, yi), (x1_, yi), sc, 1)\n",
    "        return np.clip(out, 0, 255).astype(np.uint8)\n",
    "\n",
    "    def _add_palm_features(rgb, rng, pallor):\n",
    "        \"\"\"Palm crease lines (heart/head/life lines) + thenar eminence.\"\"\"\n",
    "        out = rgb.astype(np.float32)\n",
    "        # Thenar eminence: slight brightness bulge on left side\n",
    "        cx_th, cy_th = int(IW * 0.30), int(IH * 0.65)\n",
    "        Y, X = np.ogrid[:IH, :IW]\n",
    "        th_mask = ((X - cx_th)**2 / 55**2 + (Y - cy_th)**2 / 70**2) <= 1.0\n",
    "        out[th_mask] = np.clip(out[th_mask] + rng.uniform(6, 16), 0, 255)\n",
    "        # Heart line: curves across upper palm\n",
    "        heart_pts = []\n",
    "        y0 = int(rng.uniform(55, 80))\n",
    "        for xi in range(0, IW, 8):\n",
    "            t = xi / IW\n",
    "            yi = int(y0 + 20 * np.sin(t * np.pi) + rng.uniform(-5, 5))\n",
    "            heart_pts.append((xi, int(np.clip(yi, 10, IH - 10))))\n",
    "        arr_h = np.array(heart_pts, dtype=np.int32)\n",
    "        lc = [max(0, int(out[y0, IW//2, c]) - int(rng.uniform(30, 55))) for c in range(3)]\n",
    "        out = np.clip(out, 0, 255).astype(np.uint8)  # convert once before cv2 crease drawing\n",
    "        cv2.polylines(out, [arr_h], False, lc, int(rng.integers(1, 3)))\n",
    "        # Head line: horizontal, slightly below heart line\n",
    "        head_pts = []\n",
    "        y1_ = int(rng.uniform(95, 125))\n",
    "        for xi in range(0, IW, 8):\n",
    "            yi = int(y1_ + rng.uniform(-8, 8))\n",
    "            head_pts.append((xi, int(np.clip(yi, 10, IH - 10))))\n",
    "        arr_hd = np.array(head_pts, dtype=np.int32)\n",
    "        cv2.polylines(out, [arr_hd], False, lc, int(rng.integers(1, 3)))\n",
    "        # Life line: curves from thumb base down to wrist\n",
    "        life_pts = []\n",
    "        for step in range(15):\n",
    "            t = step / 14\n",
    "            xi = int(IW * 0.15 + IW * 0.20 * np.sin(t * np.pi * 0.8))\n",
    "            yi = int(IH * 0.20 + IH * 0.65 * t + rng.uniform(-6, 6))\n",
    "            life_pts.append((int(np.clip(xi, 0, IW-1)), int(np.clip(yi, 0, IH-1))))\n",
    "        arr_lf = np.array(life_pts, dtype=np.int32)\n",
    "        cv2.polylines(out, [arr_lf], False, lc, int(rng.integers(1, 3)))\n",
    "        return np.clip(out, 0, 255).astype(np.uint8)\n",
    "\n",
    "    for cls, r in ranges.items():\n",
    "        out_dir = Path(dest_dir) / cls\n",
    "        out_dir.mkdir(parents=True, exist_ok=True)\n",
    "        pallor = list(ranges.keys()).index(cls) / max(len(ranges) - 1, 1)  # 0=healthy, 1=severe\n",
    "        for i in range(n_per_class):\n",
    "            tone_off = SKIN_TONE_V[i % len(SKIN_TONE_V)]\n",
    "            h = float(rng.uniform(*r[\"h\"]))\n",
    "            s = float(rng.uniform(*r[\"s\"]))\n",
    "            v = float(np.clip(rng.uniform(*r[\"v\"]) + tone_off, 0, 255))\n",
    "            base = np.full((IH, IW, 3), [h, s, v], dtype=np.float32)\n",
    "            # Lighting gradient\n",
    "            gt = i % 4\n",
