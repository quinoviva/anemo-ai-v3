    "            base[:,:,0] = np.clip(base[:,:,0], 0, 179)\n",
    "            base[:,:,1] = np.clip(base[:,:,1], 0, 255)\n",
    "            base[:,:,2] = np.clip(base[:,:,2], 0, 255)\n",
    "            rgb = cv2.cvtColor(base.astype(np.uint8), cv2.COLOR_HSV2RGB)\n",
    "            # Body-part-specific structural features\n",
